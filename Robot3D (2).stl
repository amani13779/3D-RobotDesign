$fn = 64;

//====================
// Body
//====================
translate([0,0,25])
cube([80,40,30], center=true);

//====================
// Head
//====================
translate([50,0,35])
cube([30,24,22], center=true);

// Nose
translate([68,0,34])
cylinder(h=8,r=5,center=true);

// Eyes
translate([58,8,40])
sphere(r=2);

translate([58,-8,40])
sphere(r=2);

// Ears
translate([48,10,48])
rotate([0,15,0])
cube([4,8,12],center=true);

translate([48,-10,48])
rotate([0,-15,0])
cube([4,8,12],center=true);

//====================
// Legs
//====================
module leg(x,y)
{
    translate([x,y,0])
    {
        cylinder(h=25,r=4);

        translate([0,0,-2])
        cube([10,14,4],center=true);
    }
}

leg(25,15);
leg(25,-15);
leg(-25,15);
leg(-25,-15);

//====================
// Tail
//====================
translate([-45,0,35])
rotate([0,35,0])
cylinder(h=25,r1=2,r2=1);

//====================
// Back Plate
//====================
translate([0,0,42])
cube([40,20,4],center=true);

//====================
// Shoulder Covers
//====================
translate([25,15,25])
sphere(r=5);

translate([25,-15,25])
sphere(r=5);

translate([-25,15,25])
sphere(r=5);

translate([-25,-15,25])
sphere(r=5);